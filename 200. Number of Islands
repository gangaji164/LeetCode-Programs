class Solution {
public:
    int numIslands(vector<vector<char>>& grid) {
       if (grid.empty()) return 0;
       int row=grid.size();
       int col=grid[0].size();
       int co=0;

       for(int r=0;r<row;r++ ){
        for(int c=0;c<col;c++){

            if (grid[r][c] == '1') {
                    co++;              
                    dfs(grid, r, c);     
                }
            }
        }
        return co;
    }    
    
    void dfs(vector<vector<char>>&grid, int r , int c){
        int rows=grid.size();
        int cols=grid[0].size();
         if(r<0|| c<0|| r>=rows|| c>=cols|| grid[r][c]=='0' )
            return;

            grid[r][c]='0';
            dfs(grid,r+1,c);
            dfs(grid,r-1,c);
            dfs(grid,r,c+1);
            dfs(grid ,r,c-1);

     }

};

         
