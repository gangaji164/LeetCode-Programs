class Solution {
public:
    int m, n;
    bool isSub; 

    void dfs(vector<vector<int>>& grid1, vector<vector<int>>& grid2, int i, int j) {
        
        if (i < 0 || j < 0 || i >= m || j >= n || grid2[i][j] == 0)
            retuarn;

        
        if (grid1[i][j] == 0)
            isSub = false;

    
        grid2[i][j] = 0;

        
        dfs(grid1, grid2, i - 1, j);
        dfs(grid1, grid2, i + 1, j);
        dfs(grid1, grid2, i, j - 1);
        dfs(grid1, grid2, i, j + 1);
    }

    int countSubIslands(vector<vector<int>>& grid1, vector<vector<int>>& grid2) {
        m = grid2.size();
        n = grid2[0].size();

        int count = 0;

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (grid2[i][j] == 1) {
                    
                    isSub = true;   

                    dfs(grid1, grid2, i, j);

                    if (isSub)
                        count++;
                }
            }
        }

        return count;
    }
};
