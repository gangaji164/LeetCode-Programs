#include <string>
#include <algorithm>
using namespace std;

class Solution {
public:
    int minOperations(string s) {
        int n = s.length();
        int start0 = 0; // pattern starting with '0'
        int start1 = 0; // pattern starting with '1'
        
        for (int i = 0; i < n; i++) {
            if (i % 2 == 0) {
                if (s[i] != '0') start0++;
                if (s[i] != '1') start1++;
            } 
            else {
                if (s[i] != '1') start0++;
                if (s[i] != '0') start1++;
            }
        }
        
        return min(start0, start1);
    }
};
